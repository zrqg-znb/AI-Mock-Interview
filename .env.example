# app runtime
SECRET_KEY=please-change-this-secret
DB_HOST=127.0.0.1
DB_PORT=3306
DB_USER=root
DB_PASSWORD=your-db-password
DB_NAME=ai_interview

# ai provider
AI_API_KEY=your-deepseek-api-key
AI_BASE_URL=https://api.deepseek.com
AI_MODEL_NAME=deepseek-chat
AI_REQUEST_TIMEOUT=18

# xfyun asr
XFYUN_APP_ID=your-xfyun-app-id
XFYUN_API_KEY=your-xfyun-api-key
XFYUN_API_SECRET=your-xfyun-api-secret
XFYUN_ASR_HOST=ws-api.xfyun.cn
XFYUN_ASR_PATH=/v2/iat
XFYUN_ASR_DOMAIN=iat
XFYUN_ASR_LANGUAGE=zh_cn
XFYUN_ASR_ACCENT=mandarin
XFYUN_ASR_VAD_EOS=10000

# optional e2e debug script
MOCK_E2E_BASE_URL=http://127.0.0.1:9999/api/v1
MOCK_E2E_USERNAME=admin
MOCK_E2E_PASSWORD=your-admin-password
MOCK_E2E_ROUNDS=3
MOCK_E2E_POSITION_ID=
MOCK_E2E_AUTO_CREATE=true
